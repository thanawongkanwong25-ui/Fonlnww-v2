-- ลูปขอบไฟวิ่งรุ้ง RGB แบบอิสระ ไม่ดึงความเร็ว Thread หลัก
local isRainbow = true
task.spawn(function()
    while isRainbow do
        for g = 0, 1, 0.02 do
            if not isRainbow then break end
            local c = Color3.fromHSV(g, 1, 1)
            if DMS and DMS.Parent then DMS.Color = c end
            if PBS and PBS.Parent then PBS.Color = c end
            if BS and BS.Parent then BS.Color = c end
            task.wait(0.01)
        end
    end
end)

-- [ANTI-LOOP BUG] ดึงสคริปต์หลักจาก GitHub มาเก็บไว้ในแรมล่วงหน้า เพื่อตัดปัญหาการโหลดวนซ้ำ
local githubRawCode = ""
local downloadSuccess = false

task.spawn(function()
    pcall(function()
        githubRawCode = game:HttpGet("https://githubusercontent.com")
        downloadSuccess = true
    end)
end)

-- แอนิเมชันรัน % ดาวน์โหลดควบคู่ไปกับการดึงสคริปต์จาก GitHub
for i = 0, 100 do
    -- หน่วงเวลาแถบวิ่งช่วงปลาย (95%) เพื่อรอให้ระบบ Android ดึงสคริปต์ทางอินเทอร์เน็ตเสร็จก่อน
    if i >= 95 and not downloadSuccess then
        while not downloadSuccess do task.wait(0.05) end
    end
    
    if PT and PF then
        PT.Text = i .. "%"
        PF.Size = UDim2.new(i / 100, 0, 1, 0)
    end
    task.wait(0.01)
end

-- [FORCE SHUTDOWN LOADING] ทำลายระเบิดหน้าจอโหลดทิ้งแบบถาวร เพื่อไม่มีทางวนลูปกลับมาได้อีก
isRainbow = false
_G.FonMainLoaderActive = nil
if LS then LS:Destroy() end
BT.Visible = true

-- แปลงข้อความที่ดึงมาจาก GitHub และสั่งเปิดโปรหลักทำงานทันที
if downloadSuccess and githubRawCode ~= "" then
    local runScript = loadstring(githubRawCode)
    if runScript then
        task.spawn(runScript)
    end
end

