CreateBtn("เปิด/ปิด ความเร็วสูง (Speed)",function(b) S_Act=not S_Act b.BackgroundColor3=S_Act and Color3.fromRGB(0,180,100) or Color3.fromRGB(45,45,45) local h=GetChar():FindFirstChildOfClass("Humanoid") if h then h.WalkSpeed=S_Act and C_Spd or 16 end end)
