CreateBtn("เปิด/ปิด เดินทะลุบล็อก (Noclip)",function(b) N_Act=not N_Act b.BackgroundColor3=N_Act and Color3.fromRGB(0,180,100) or Color3.fromRGB(45,45,45) end)
R.Stepped:Connect(function() if N_Act and LP.Character then for _,p in pairs(LP.Character:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide=false end end end end)

CreateBtn("เปิด/ปิด ระบบบิน (Fly)", function(b)
    F_Act = not F_Act
    b.BackgroundColor3 = F_Act and Color3.fromRGB(0, 180, 100) or Color3.fromRGB(45, 45, 45)
    local r = GetChar():FindFirstChild("HumanoidRootPart")
    if not r then return end
    if F_Act then
        local bv = Instance.new("BodyVelocity", r)
        bv.Name = "FlyVelocity"
        bv.MaxForce = Vector3.new(1e5, 1e5, 1e5)
        local bg = Instance.new("BodyGyro", r)
        bg.Name = "FlyGyro"
        bg.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
        task.spawn(function()
            while F_Act and r and r.Parent do
                local h = GetChar():FindFirstChildOfClass("Humanoid")
                local cam = W.CurrentCamera
                if h and cam then
                    if h.MoveDirection.Magnitude > 0 then
                        bv.Velocity = cam.CFrame.LookVector * F_Spd
                    else
                        bv.Velocity = Vector3.new(0, 0, 0)
                    end
                    bg.CFrame = cam.CFrame
                end
                task.wait()
            end
            if bv then bv:Destroy() end
            if bg then bg:Destroy() end
        end)
    else
        local v, g = r:FindFirstChild("FlyVelocity"), r:FindFirstChild("FlyGyro")
        if v then v:Destroy() end
        if g then g:Destroy() end
    end
end)

CreateInp("พิมพ์เลขเพื่อตั้งความเร็วบิน (เช่น 50)",F_Spd,function(v) F_Spd=v end)

CreateBtn("ล้างขยะในแมพลดอาการแลค (Detax)", function(b)
    local count = 0
    for _, o in pairs(W:GetDescendants()) do
        if o:IsA("Decal") or o:IsA("Texture") or o:IsA("Smoke") or o:IsA("Sparkles") or o:IsA("Fire") then
            if not o:FindFirstAncestorOfClass("Model") or not P:GetPlayerFromCharacter(o:FindFirstAncestorOfClass("Model")) then
                o:Destroy()
                count = count + 1
            end
        elseif o:IsA("BasePart") and o.Parent == W and not o.Anchored then
            o:Destroy()
            count = count + 1
        end
    end
    local oldText = b.Text
    b.Text = "⚡ ล้างสำเร็จ! ลบไป " .. tostring(count) .. " ชิ้น"
    task.wait(2)
    b.Text = oldText
end)
